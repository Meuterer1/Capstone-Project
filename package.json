{
  "name": "fundamentals-project-ts-template",
  "version": "1.0.0",
  "description": "Capstone Project TS Template",
  "main": "index.js",
  "scripts": {
    "build": "tsc && sass src/scss:dist/css --style=compressed && powershell -Command \"Copy-Item -Recurse src/assets dist/assets; Copy-Item -Recurse src/html dist/html; Copy-Item -Recurse src/dist/js dist/js; Copy-Item src/index.html dist/index.html; Get-ChildItem dist -Recurse -Filter *.html | ForEach-Object { (Get-Content $_.FullName) -replace '\\.\\./dist/', '../' -replace '\\./dist/', './' | Set-Content $_.FullName }\"",
    "lint": "npm run lint:eslint && npm run lint:style",
    "lint:eslint": "eslint .",
    "lint:style": "stylelint \"**/*.{css}\"",
    "ts-compile": "tsc --watch",
    "sass-compile": "sass --watch src/scss:src/dist/css",
    "serve": "live-server src --port=8080 --wait=700 --open=/index.html",
    "preview": "live-server dist --port=8080 --wait=700 --open=/index.html",
    "dev": "concurrently \"npm run ts-compile\" \"npm run sass-compile\" \"npm run serve\""
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@eslint/css": "^1.1.0",
    "@eslint/js": "^10.0.1",
    "@html-eslint/eslint-plugin": "^0.59.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "live-server": "^1.2.2",
    "stylelint": "^17.6.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.0.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "sass": "^1.99.0"
  },
  "settings": {
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 300,
    "liveServer.settings.fullReload": true,
    "liveServer.settings.useWebExt": false,
    "liveServer.settings.wait": 100
  }
}
